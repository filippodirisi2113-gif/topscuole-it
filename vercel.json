{
      "version": 2,
      "name": "topscuole-it",
      "cleanUrls": true,
      "rewrites": [
              {
                        "source": "/schools",
                        "destination": "/schools.html"
              },
              {
                        "source": "/scuola/(.*)",
                        "destination": "/school-detail.html"
              }
      ],
      "headers": [
              {
                        "source": "/(.*)",
                        "headers": [
                                    {
                                                  "key": "X-Content-Type-Options",
                                                  "value": "nosniff"
                                    },
                                    {
                                                  "key": "X-Frame-Options",
                                                  "value": "DENY"
                                    },
                                    {
                                                  "key": "X-XSS-Protection",
                                                  "value": "1; mode=block"
                                    }
                        ]
              }
      ]
}
