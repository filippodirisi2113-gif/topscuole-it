# Firebase Configuration — Environment Variables
# Copia questo file in firebase-config.js e sostituisci i valori

FIREBASE_API_KEY=INSERISCI_LA_TUA_API_KEY
FIREBASE_AUTH_DOMAIN=topscuole-it.firebaseapp.com
FIREBASE_PROJECT_ID=topscuole-it
FIREBASE_STORAGE_BUCKET=topscuole-it.appspot.com
FIREBASE_MESSAGING_SENDER_ID=INSERISCI_IL_TUO_MESSAGING_SENDER_ID
FIREBASE_APP_ID=INSERISCI_IL_TUO_APP_ID

# IMPORTANTE: Non aggiungere mai il file .env con valori reali al repository pubblico!
# Aggiungi .env al tuo .gitignore
